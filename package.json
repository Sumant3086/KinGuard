{
  "name": "kinguard",
  "version": "1.0.0",
  "description": "Loss & Prevention Inventory Reconciliation System",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=client",
    "migrate": "npm run migrate --workspace=server",
    "seed": "npm run seed --workspace=server"
  },
  "keywords": [
    "inventory",
    "reconciliation",
    "loss-prevention"
  ],
  "author": "",
  "license": "ISC"
}
