{
  "name": "kinguard",
  "version": "1.0.0",
  "description": "Loss & Prevention Inventory Reconciliation System",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "node server/src/server.js",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"wait-on http://localhost:5000/api/health --timeout 30000 && npm run dev --workspace=client\"",
    "test:unit": "npm run test --workspace=server",
    "test:e2e": "npm run test:e2e --workspace=client",
    "install:all": "npm install",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=client",
    "start:server": "npm run start --workspace=server",
    "migrate": "npm run migrate --workspace=server",
    "seed": "npm run seed --workspace=server",
    "db:reset": "npm run db:reset --workspace=server",
    "db:clear": "npm run db:clear --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "wait-on": "^9.0.10"
  },
  "keywords": [
    "inventory",
    "reconciliation",
    "loss-prevention"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  }
}
