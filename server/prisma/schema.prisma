generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STORE_MANAGER
}

enum UploadStatus {
  PENDING
  COMPLETED
  FAILED
}

enum InventoryStatus {
  PENDING
  SUBMITTED
}

model Store {
  id        Int      @id @default(autoincrement())
  storeCode String   @unique
  storeName String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  inventoryRecords    InventoryRecord[]
  deadlineExtensions  BatchDeadlineExtension[]

  @@index([storeCode])
}

model User {
  id                 Int      @id @default(autoincrement())
  employeeId         String   @unique
  name               String
  passwordHash       String
  role               UserRole
  storeId            Int?
  isActive           Boolean  @default(true)
  pendingApproval    Boolean  @default(false)
  mustChangePassword Boolean  @default(false)
  source             String   @default("MANUAL")
  email              String?  @unique
  phone              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store                Store?            @relation(fields: [storeId], references: [id])
  uploadBatches        UploadBatch[]
  submittedRecords     InventoryRecord[] @relation("SubmittedBy")
  auditLogs            AuditLog[]
  deadlineExtensions   BatchDeadlineExtension[] @relation("DeadlineExtensions")
  refreshTokens        RefreshToken[]

  @@index([employeeId])
  @@index([storeId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UploadBatch {
  id                 Int          @id @default(autoincrement())
  originalFileName   String
  storedFileName     String?
  uploadedBy         Int
  uploadedAt         DateTime     @default(now())
  inventoryDate      DateTime
  submissionDeadline DateTime?
  autoReminderSentAt DateTime?
  totalRows          Int          @default(0)
  successfulRows     Int          @default(0)
  rejectedRows       Int          @default(0)
  status             UploadStatus @default(PENDING)

  uploader            User              @relation(fields: [uploadedBy], references: [id])
  inventoryRecords    InventoryRecord[]
  deadlineExtensions  BatchDeadlineExtension[]

  @@index([uploadedBy])
  @@index([inventoryDate])
  @@index([status])
}

model InventoryRecord {
  id               Int              @id @default(autoincrement())
  batchId          Int
  storeId          Int
  materialCode     String
  materialName     String
  systemQuantity   Float
  physicalQuantity Float?
  difference       Float?
  remarks           String?
  shrinkageCategory String?
  status            InventoryStatus  @default(PENDING)
  submittedBy      Int?
  submittedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  batch         UploadBatch @relation(fields: [batchId], references: [id])
  store         Store       @relation(fields: [storeId], references: [id])
  submitter     User?       @relation("SubmittedBy", fields: [submittedBy], references: [id])

  @@unique([batchId, storeId, materialCode])
  @@index([batchId])
  @@index([storeId])
  @@index([materialCode])
  @@index([status])
  @@index([submittedAt])
  @@index([storeId, batchId])
  @@index([storeId, status])
  @@index([batchId, status])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String?
  entityId   Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model BatchDeadlineExtension {
  id          Int      @id @default(autoincrement())
  batchId     Int
  storeId     Int
  newDeadline DateTime
  grantedBy   Int
  grantedAt   DateTime @default(now())
  note        String?

  batch   UploadBatch @relation(fields: [batchId], references: [id])
  store   Store       @relation(fields: [storeId], references: [id])
  granter User        @relation("DeadlineExtensions", fields: [grantedBy], references: [id])

  @@unique([batchId, storeId])
  @@index([batchId])
  @@index([storeId])
}
