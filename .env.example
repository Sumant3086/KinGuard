# ─── Database ────────────────────────────────────────────────────────────────
# Prisma connection URL (pooled connection used by the app)
DATABASE_URL=postgresql://user:password@localhost:5432/kinguard

# Direct (non-pooled) URL — required by Prisma CLI for migrations.
# For local PostgreSQL: set this to the same value as DATABASE_URL.
# For Supabase: use the "Direct connection" string from your Supabase project settings.
DIRECT_URL=postgresql://user:password@localhost:5432/kinguard

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace-this-with-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=8h

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to the URL where the frontend is served in production
CLIENT_URL=http://localhost:5173

# ─── Email notifications (SMTP) ──────────────────────────────────────────────
# Leave blank to disable email notifications entirely.
# Gmail: use an App Password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=KinMarché <noreply@kinmarche.com>

# ─── WhatsApp reminders ───────────────────────────────────────────────────────
# WhatsApp uses wa.me click-to-chat links — no API key required.
# Admin clicks "WhatsApp" on a batch → selects a store → WhatsApp opens in browser
# with a pre-written reminder message ready to send.
#
# SETUP: Add each store manager's phone number (with country code) in User Management.
# e.g. +243812345678  (DRC)  /  +27821234567  (South Africa)
#
# Email reminders are sent via the SMTP settings above.
# Click "Email" on a batch to instantly email all pending store managers.
